# Çalışma modu — local (polling, kendi token'ın) | hosted (tek demo)
ENSEMBLE_MODE=local

# Hosted platform secret seti (#186 — S3 go-live boşluk analizi): Fly/Render'a
# bunların hepsi env-secret olarak set edilmeli (dosya değil):
#   GEMINI_API_KEY · GITHUB_APP_ID · GITHUB_APP_INSTALLATION_ID ·
#   GITHUB_APP_PRIVATE_KEY (bkz. aşağıda — dosya-yolu değil, PEM içeriği) ·
#   GITHUB_WEBHOOK_SECRET · DATABASE_URL · CORS_ORIGINS

# Gemini (embeddings + judge)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768
GEMINI_TIMEOUT_S=10
GEMINI_MAX_RETRIES=3

# GitHub App (machine auth — ingest)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
# Hosted alternatifi (#186) — Fly/Render secret'ları dosya değil env-string;
# PATH boşsa bu alan (PEM içeriği, ham metin) kullanılır. İkisi de boşsa
# mevcut graceful degradasyon (FakeGitHubAdapter) devreye girer.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_DEFAULT_BRANCH=main
GITHUB_BACKFILL_LIMIT=50
# Webhook (kayıtta aktif; canlı alıcı S3 #62 — geçici hedef smee kanalı, D-35)
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_PROXY_URL=

# Radar eşikleri (#151, kalibre: #18) — 0.0/0.0 kalibrasyon SONUCU, placeholder
# değil: sweep (#29, eval/sweep_results.json) 60 kombinasyonun hiçbirinde FP
# eklemeden recall kazandırmıyor — mevcut korpuste FP'yi engelleyen gate/judge
# katmanı, jaccard/similarity değil. Detay + şerhler: eval/kalibrasyon-raporu.md
RADAR_WINDOW_DAYS=14
RADAR_MIN_JACCARD=0.0
RADAR_MIN_SIMILARITY=0.0

# Store (local: sqlite dosya yolu · hosted: postgres dsn)
DATABASE_URL=

# Frontend (Vite) — backend base URL
VITE_API_BASE_URL=http://localhost:8000
# Mock modu (#21) — yalnız "1" kabul edilir: frontend fixture verisiyle çalışır
# (UI'da "Örnek veri" rozeti görünür); başka değer açılışta net hata verir
VITE_MOCK=

# CORS allowlist (virgüllü, #45) — asla "*". Boş bırakma; set etmezsen local
# varsayılanları geçerli: http://localhost:5173 + http://127.0.0.1:5173
# Hosted örneği:
# CORS_ORIGINS=https://ensemble-demo.vercel.app
