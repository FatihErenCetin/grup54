            }
          },
          "503": {
            "description": "Gecici olarak erisilemez",
            "headers": {
              "Retry-After": {
                "description": "Saniye — yalniz kendiliginden duzelebilir durumlarda",
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
