                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/scope/check": {
      "get": {
        "tags": [
          "scope"
        ],
        "summary": "Check Scope",
        "operationId": "check_scope_scope_check_get",
        "parameters": [
          {
            "name": "ref",
            "in": "query",
            "required": true,
