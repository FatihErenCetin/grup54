        "properties": {
          "cards": {
            "items": {
              "$ref": "#/components/schemas/BoardCard"
            },
            "type": "array",
            "title": "Cards"
          }
        },
        "type": "object",
        "required": [
          "cards"
        ],
        "title": "BoardResponse"
      },
      "Citation": {
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "scope",
              "task",
              "decision",
              "event",
              "pr"
            ],
            "title": "Type"
          },
          "ref": {
            "type": "string",
            "title": "Ref"
          },
          "quote": {
            "type": "string",
            "title": "Quote"
          },
          "url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Url"
          },
          "range": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/LineRange"
              },
              {
                "type": "null"
              }
            ]
          },
          "n": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "N"
          }
        },
        "type": "object",
        "required": [
          "type",
          "ref",
          "quote"
        ],
        "title": "Citation"
      },
      "Detection": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "kind": {
            "type": "string",
            "const": "conflict",
            "title": "Kind",
            "default": "conflict"
          },
          "actors": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Actors"
          },
          "branches": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Branches"
          },
          "files": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Files"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "med",
              "high"
            ],
            "title": "Severity"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "rationale": {
            "type": "string",
            "title": "Rationale"
          }
        },
        "type": "object",
        "required": [
          "id",
          "actors",
          "branches",
          "files",
          "severity",
          "confidence",
          "rationale"
        ],
        "title": "Detection"
      },
