  "components": {
    "schemas": {
      "BoardCard": {
        "properties": {
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "status": {
            "type": "string",
            "enum": [
              "backlog",
              "todo",
              "in_progress",
              "in_review",
              "done"
            ],
            "title": "Status"
          },
          "assignee": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Assignee"
          },
          "ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ref"
          }
        },
        "type": "object",
        "required": [
          "task_id",
          "title",
          "status",
          "assignee",
          "ref"
        ],
        "title": "BoardCard"
      },
      "BoardResponse": {
        "properties": {
          "cards": {
            "items": {
              "$ref": "#/components/schemas/BoardCard"
            },
            "type": "array",
            "title": "Cards"
          }
        },
        "type": "object",
        "required": [
          "cards"
        ],
        "title": "BoardResponse"
      },
      "Detection": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "kind": {
            "type": "string",
            "const": "conflict",
            "title": "Kind",
            "default": "conflict"
          },
          "actors": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Actors"
          },
          "branches": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Branches"
          },
          "files": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Files"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "med",
              "high"
            ],
            "title": "Severity"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "rationale": {
            "type": "string",
            "title": "Rationale"
          }
        },
        "type": "object",
        "required": [
          "id",
          "actors",
          "branches",
          "files",
          "severity",
          "confidence",
          "rationale"
        ],
        "title": "Detection"
      },
      "ErrorEnvelope": {
        "properties": {
          "error": {
            "type": "string",
            "title": "Error"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "status": {
            "type": "integer",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "error",
          "message",
          "status"
        ],
        "title": "ErrorEnvelope"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "const": "ok",
            "title": "Status"
          },
          "mode": {
            "type": "string",
            "enum": [
              "local",
              "hosted"
            ],
            "title": "Mode"
          }
        },
        "type": "object",
        "required": [
          "status",
          "mode"
        ],
        "title": "HealthResponse"
      },
      "QueryResponse": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "citations": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Citations"
          }
        },
        "type": "object",
        "required": [
          "answer",
          "citations"
        ],
        "title": "QueryResponse"
      },
      "RadarResponse": {
        "properties": {
          "detections": {
            "items": {
              "$ref": "#/components/schemas/Detection"
            },
            "type": "array",
            "title": "Detections"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "detections",
          "updated_at"
        ],
        "title": "RadarResponse"
      },
      "ScopeCurrent": {
        "properties": {
          "goal": {
            "type": "string",
            "minLength": 1,
            "title": "Goal"
          },
          "in_scope": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "In Scope"
          },
          "non_goals": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Non Goals"
          },
          "version": {
            "type": "string",
            "minLength": 1,
            "title": "Version"
          },
          "frozen_at": {
            "type": "string",
            "format": "date-time",
            "title": "Frozen At"
          },
          "ref": {
            "type": "string",
            "minLength": 1,
            "title": "Ref"
          },
          "commit_sha": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{7,64}$",
            "title": "Commit Sha"
          }
        },
        "type": "object",
        "required": [
          "goal",
          "in_scope",
          "non_goals",
          "version",
          "frozen_at",
          "ref",
          "commit_sha"
        ],
        "title": "ScopeCurrent"
      },
      "ScopeItemRef": {
        "properties": {
          "quote": {
            "type": "string",
            "title": "Quote"
          },
          "item_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Item Id"
          },
          "section": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "goal",
                  "in_scope",
                  "non_goals"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Section"
          },
          "line": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Line"
          }
        },
        "type": "object",
        "required": [
          "quote"
        ],
        "title": "ScopeItemRef"
      },
      "ScopeVerdict": {
        "properties": {
          "ref": {
            "type": "string",
            "title": "Ref"
          },
          "verdict": {
            "type": "string",
            "enum": [
              "in_scope",
              "drift",
              "non_goal_violation"
            ],
            "title": "Verdict"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "evidence": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/components/schemas/ScopeItemRef"
              }
            ],
            "title": "Evidence"
          },
          "match_none": {
            "type": "boolean",
            "title": "Match None",
            "default": false
          },
          "judged_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Judged At"
          },
          "signals": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Signals"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "ref",
          "verdict",
          "confidence",
          "evidence"
        ],
        "title": "ScopeVerdict"
      },
      "ScopeVerdictCounts": {
        "properties": {
          "in_scope": {
            "type": "integer",
            "title": "In Scope"
          },
          "drift": {
            "type": "integer",
            "title": "Drift"
          },
          "non_goal_violation": {
            "type": "integer",
            "title": "Non Goal Violation"
          }
        },
        "type": "object",
        "required": [
          "in_scope",
          "drift",
          "non_goal_violation"
        ],
        "title": "ScopeVerdictCounts"
      },
      "ScopeVerdictsResponse": {
        "properties": {
          "verdicts": {
            "items": {
              "$ref": "#/components/schemas/ScopeVerdict"
            },
            "type": "array",
            "title": "Verdicts"
          },
          "counts": {
            "$ref": "#/components/schemas/ScopeVerdictCounts"
          },
          "judged_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Judged At"
          }
        },
        "type": "object",
        "required": [
          "verdicts",
          "counts",
          "judged_at"
        ],
        "title": "ScopeVerdictsResponse"
      },
      "Signals": {
        "properties": {
          "files": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Files"
          },
          "matched_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Matched Text"
          }
        },
        "type": "object",
        "required": [
          "files"
        ],
        "title": "Signals"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}