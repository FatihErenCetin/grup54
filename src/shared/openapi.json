    "/query": {
      "get": {
        "tags": [
          "query"
        ],
        "summary": "Ask Project",
        "operationId": "ask_project_query_get",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Q"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
