      "BoardCard": {
        "properties": {
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "status": {
            "type": "string",
            "enum": [
              "backlog",
              "todo",
              "in_progress",
              "in_review",
              "done"
